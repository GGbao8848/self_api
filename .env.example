# 当前客户端的文件访问根目录和存储根目录
SELF_API_FILE_ACCESS_ROOTS=/Users/dir                                       #!!!!!!!!!!!!!!!!!这里要改!!!!本机文件访问根目录!!!!!!!!!!!!!
SELF_API_STORAGE_ROOT=./storage

# 当前客户端ip和端口，用于生成异步任务状态 URL
SELF_API_PUBLIC_BASE_URL=http://127.0.0.1:8666
SELF_API_AUTH_ENABLED=false
# SELF_API_AUTH_ADMIN_USERNAME=admin
# SELF_API_AUTH_ADMIN_PASSWORD=123456
# SELF_API_AUTH_SECRET_KEY=1234567

# 内建 Agent 的默认模型配置
SELF_API_LLM_DEFAULT_PROVIDER=ollama
SELF_API_LLM_DEFAULT_MODEL=gemma4:e4b
SELF_API_LLM_REQUEST_TIMEOUT_SECONDS=60
SELF_API_OPENAI_API_KEY=
SELF_API_OPENAI_BASE_URL=
SELF_API_OPENROUTER_API_KEY=your_openrouter_api_key_here
SELF_API_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SELF_API_OLLAMA_BASE_URL=http://192.168.1.231:11434                        #!!!!!!!!!!!!!!!!!这里要改!!!!OLLAMA主机IP!!!!!!!!!!!!!
SELF_API_OLLAMA_MODEL=gemma4:e4b
SELF_API_AGENT_MAX_STEPS=8
SELF_API_AGENT_TOOL_CALL_LIMIT=1
SELF_API_AGENT_ENABLE_STREAMING=false

# 增量发布数据集时，本地 staging 工作区默认放这里；不填则自动回落到 SELF_API_STORAGE_ROOT/publish_workspace
SELF_API_PUBLISH_PROJECT_ROOT_DIR=/media/qzq/16T/TEDS/langgraph_workspace/publish_workspace

# 远端增量数据发布 / 远端 last_yaml 读取默认走这里的 SFTP / SSH 配置
SELF_API_REMOTE_SFTP_HOST=172.31.1.XX                                       #!!!!!!!!!!!!!!!!!这里要改!!!!远端主机IP!!!!!!!!!!!!!
SELF_API_REMOTE_SFTP_USERNAME=your_user                                     #!!!!!!!!!!!!!!!!!这里要改!!!!SSH用户名!!!!!!!!!!!!!
SELF_API_REMOTE_SFTP_PRIVATE_KEY_PATH=/home/your_user/.ssh/id_ed25519       #!!!!!!!!!!!!!!!!!这里要改!!!!是SSH私钥路径!!!!!!!!!!!!!
SELF_API_REMOTE_SFTP_PORT=22 

# Docker 容器运行用户（避免宿主机挂载目录出现 root 权限文件）
# UID=1000
# GID=1000
