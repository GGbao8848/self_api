# 当前客户端的文件访问根目录和存储根目录
SELF_API_FILE_ACCESS_ROOTS=/Users/dir
SELF_API_STORAGE_ROOT=/Users/dir/storage

# 当前客户端ip和端口，用于与n8n通信
SELF_API_PUBLIC_BASE_URL=http://127.0.0.1:8666
SELF_API_AUTH_ENABLED=true
SELF_API_AUTH_ADMIN_USERNAME=admin
SELF_API_AUTH_ADMIN_PASSWORD=123456
SELF_API_AUTH_SECRET_KEY=1234567


# LangGraph 管线 checkpointer：memory（默认，重启丢失）或 sqlite（run 可跨进程恢复）
SELF_API_PIPELINE_CHECKPOINTER=memory
SELF_API_PIPELINE_SQLITE_PATH=./storage/pipeline_checkpoints.sqlite

# 【已废弃】 以下两项仅保留用于向外部 n8n 实例发回调；项目编排已全部切换到 LangGraph
SELF_API_N8N_BASE_URL=
SELF_API_N8N_API_KEY=

# Docker 容器运行用户（避免宿主机挂载目录出现 root 权限文件）
UID=1000
GID=1000

