    {
      "parameters": {
        "toolDescription": "【YOLO 标签索引修改】input_dir 可传三种路径：1) labels 目录本身；2) 数据集根目录（其下有 labels/）；3) 更上层父目录（将递归发现其中所有名为 labels 的文件夹）。该工具是同步接口，直接原地修改所有命中的 labels 目录及其子目录下 .txt，不需要轮询。支持两种主要模式：1) 盲改全部到指定索引：只传 default_target_index，例如全部改成1；2) 自定义映射：传 mapping_json（JSON对象字符串，例如 {\"0\":0,\"1\":0,\"2\":0}），并可选 default_target_index 处理未列出的其余索引，例如 0到5改成0，其余改成1。若用户明确要求直接修改，不要先调用查询工具。",
        "method": "POST",
        "url": "http://192.168.2.26:8666/api/v1/preprocess/rewrite-yolo-label-indices",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "input_dir",
              "value": "={{ $fromAI('input_dir', '', 'string').trim().replace(/\\/+$/,'') }}"
            },
            {
              "name": "recursive",
              "value": "={{ (($fromAI('recursive', 'true', 'string') || 'true').trim().toLowerCase()) !== 'false' }}"
            },
            {
              "name": "mapping",
              "value": "={{ (() => { const raw = ($fromAI('mapping_json', '{}', 'string') || '{}').trim(); return JSON.parse(raw || '{}'); })() }}"
            },
            {
              "name": "default_target_index",
              "value": "={{ (() => { const raw = ($fromAI('default_target_index', '', 'string') || '').trim(); return raw === '' ? null : Number(raw); })() }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
